# Copy to `.env` for local overrides, or use `.env.development` with APP_ENV=development
APP_ENV=development

MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=pandore

JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256

# Stripe — https://dashboard.stripe.com/apikeys
# Secret key (sk_test_… / sk_live_…) : uniquement sur le serveur, jamais dans le front.
STRIPE_API_KEY=
# Webhook signing secret (whsec_…) : destination *snapshot* → POST /api/webhook/stripe
STRIPE_WEBHOOK_SECRET=
# Même principe pour la destination *thin* → POST /api/webhook/stripe/thin (secret différent)
STRIPE_WEBHOOK_SECRET_THIN=
# Devise des prix (unit_amount en centimes). ex. eur, usd
STRIPE_CURRENCY=eur
# Stripe Connect : commission plateforme sur chaque vente (pourcentage)
STRIPE_PLATFORM_FEE_PERCENT=15
# true = les vendeurs doivent avoir un compte Connect Express (recommandé prod). false = tout sur le compte plateforme (dev)
STRIPE_CONNECT_ENABLED=true
# URL du front pour les retours onboarding Connect (ex. http://localhost:3000)
PUBLIC_FRONTEND_URL=http://localhost:3000
# Indication UI seuil de virement (les règles réelles sont dans Stripe / pays)
STRIPE_MIN_PAYOUT_HINT_EUROS=20

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
FRONTEND_OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# Comma-separated origins, or * (dev only)
CORS_ORIGINS=http://localhost:3000
