# Production template — prefer setting these in Railway dashboard (secrets).
# If you deploy this file, fill MONGO_URL and secrets; never commit real secrets.

APP_ENV=production

MONGO_URL=
DB_NAME=pandore

JWT_SECRET=
JWT_ALGORITHM=HS256

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public Railway URL for the API (not *.railway.internal)
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_API_PUBLIC_HOST/api/auth/google/callback
FRONTEND_OAUTH_REDIRECT_URL=https://kloud-snk.netlify.app/auth/callback

# Browser origin(s) for your Netlify app
CORS_ORIGINS=https://kloud-snk.netlify.app


STRIPE_API_KEY=sk_test_51PqDKU09bQ5LKxrkaZ9P4yX4gLWxLpA1xgPZ7GPtoGTbdOXxiBdAW6hrDV1BhiVgwoXbK007Uu8tV9Q73kvr4Q4g007yq0USg9
# Webhook signing secret (whsec_…) : Dashboard → Developers → Webhooks → ton endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_XnEtOEalVOOrP2tskYPTaH7s3Qkrd1Fu
# Devise des prix (unit_amount en centimes). ex. eur, usd
STRIPE_CURRENCY=eur
# Même principe pour la destination *thin* → POST /api/webhook/stripe/thin (secret différent)
STRIPE_WEBHOOK_SECRET_THIN=whsec_11ir3b1b8uscorUuwpmcDVk4gVUkc98m
# Stripe Connect : commission plateforme sur chaque vente (pourcentage)
STRIPE_PLATFORM_FEE_PERCENT=15
# true = les vendeurs doivent avoir un compte Connect Express (recommandé prod). false = tout sur le compte plateforme (dev)
STRIPE_CONNECT_ENABLED=true
# URL du front pour les retours onboarding Connect (ex. http://localhost:3000)
PUBLIC_FRONTEND_URL=http://localhost:3000
# Indication UI seuil de virement (les règles réelles sont dans Stripe / pays)
STRIPE_MIN_PAYOUT_HINT_EUROS=20